# SSH Server Configuration
DEPLOY_HOST=192.168.2.133
DEPLOY_PORT=22
DEPLOY_USER=jingdor
DEPLOY_KEY_PATH=~/.ssh/id_rsa

# Remote Paths
DEPLOY_REMOTE_PATH=/var/www/kaleidoscope
DEPLOY_BACKUP_PATH=/var/www/kaleidoscope-backups

# Deployment Options
DEPLOY_KEEP_BACKUPS=5
DEPLOY_RESTART_SERVICE=true
DEPLOY_SERVICE_NAME=kaleidoscope

# Environment
DEPLOY_ENV=production

# Frontend API URL (optional, e.g., http://api.example.com)
API_BASE_URL=
